# AWS Credentials (Required)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# AWS DynamoDB Table Names
DYNAMODB_USERS_TABLE=adapted-users
DYNAMODB_ROADMAPS_TABLE=adapted-roadmaps
DYNAMODB_VIVA_SESSIONS_TABLE=adapted-viva-sessions

# AWS S3 Bucket for Audio Files
S3_AUDIO_BUCKET=adapted-audio-files

# YouTube API (Optional - for video search)
YOUTUBE_API_KEY=your_youtube_api_key

# Note: This application uses AWS services:
# - AWS Bedrock (Claude 3) for AI content generation
# - AWS DynamoDB for database storage
# - AWS Transcribe for speech-to-text
# - AWS Polly for text-to-speech
# - AWS S3 for file storage
